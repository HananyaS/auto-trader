# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# --- Alpaca credentials ---
# Get keys from https://app.alpaca.markets/ (use Paper keys first).
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# Trading mode: "paper" (default, safe) or "live" (real money).
# Keep this on paper until the strategy is validated.
ALPACA_ENV=paper

# --- Risk / sizing defaults (PDT-aware, account under $25k) ---
# Fraction of equity risked per trade (0.01 = 1%).
RISK_PER_TRADE=0.01
# Hard ceilings enforced by the risk layer.
MAX_POSITION_PCT=0.10
MAX_CONCURRENT_POSITIONS=5
MAX_PORTFOLIO_EXPOSURE=0.60
# Daily loss kill-switch as a fraction of equity (0.03 = halt at -3%).
DAILY_MAX_LOSS=0.03
# Pattern Day Trader cap for margin accounts under $25k.
PDT_MAX_DAY_TRADES=3
